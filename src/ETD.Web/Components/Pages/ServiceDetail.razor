@page "/leistungen/{Slug}"
@using ETD.Web.Models
@using ETD.Web.Services
@using ETD.Web.Components.Shared
@inject IHttpContextAccessor HttpCtx

@code {
    [Parameter] public string Slug { get; set; } = "";
    private ServiceItem? service;
    private ServiceVisual? visual;

    protected override void OnParametersSet()
    {
        service = ServiceCatalog.FindBySlug(Slug);
        visual = service is null ? null : ServiceVisuals.GetValueOrDefault(service.Slug);

        if (service is null && HttpCtx.HttpContext is { } ctx && !ctx.Response.HasStarted)
        {
            ctx.Response.StatusCode = 404;
        }
    }

    private static readonly Dictionary<string, ServiceVisual> ServiceVisuals = new()
    {
        ["elektroinstallation"] = new(
            "Ausführung",
            "Ordnung im Verteiler, Ruhe im Betrieb.",
            "Gute Elektroinstallation fällt im Alltag nicht auf. In der Verteilung sieht man trotzdem, ob sauber geplant, beschriftet und montiert wurde.",
            [
                new("hero-cropped-IMG_20200508_120948.jpg", "Hager Sicherungsautomaten in einer Unterverteilung", "Unterverteilung"),
                new("referenz-08.jpg", "Modernisierte Sicherungsverteilung", "Modernisierung"),
                new("referenz-10.jpg", "Leuchteninstallation an einer Decke", "Beleuchtung"),
            ]),

        ["smart-home-knx"] = new(
            "Designschalter",
            "Smart Home darf technisch stark und optisch ruhig sein.",
            "KNX bleibt im Hintergrund. Sichtbar sind nur die Bedienstellen, deshalb stimmen wir Schalterprogramme und Bedienpunkte sauber auf Raum und Nutzung ab.",
            [
                new("gira-schalter-standard-55.jpg", "Gira Standard 55 Schalter", "Gira Standard 55"),
                new("gira-schalter-e2.jpg", "Gira E2 Schalter", "Gira E2"),
                new("gira-schalter-e3.jpg", "Gira E3 Schalter", "Gira E3"),
            ]),

        ["sprechanlagen"] = new(
            "Türkommunikation",
            "Klingel, Sprache, Video und Zutritt aus einem System.",
            "Von klassischer Audio-Sprechanlage bis moderner Videolösung: Wir planen die passende Türkommunikation für Bestand und Neubau.",
            [
                new("bosch-pio00016669.jpg", "Ritto Twinbus Türstation", "Ritto Twinbus"),
                new("seano-tile-300x178.png", "Schalter- und Steckdosenprogramm", "Designprogramm"),
            ]),

        ["beleuchtung"] = new(
            "Lichtbild",
            "Gutes Licht entsteht aus Planung und sauberer Montage.",
            "Beleuchtung muss zum Raum, zur Nutzung und zur späteren Wartung passen. Wir kümmern uns um Aufbau, Anschluss und die passende Schaltung.",
            [
                new("referenz-10.jpg", "Montierte Deckenleuchten", "Deckenleuchten"),
                new("referenz-12.jpg", "Beleuchtung und Verkabelung in der Endmontage", "Endmontage"),
                new("referenz-01.jpg", "Wohnrauminstallation mit Lichtplanung", "Wohnraum"),
            ]),
    };

    private sealed record ServiceVisual(string Eyebrow, string Title, string Text, IReadOnlyList<ServiceVisualImage> Images);

    private sealed record ServiceVisualImage(string File, string Alt, string Caption);
}

@if (service is null)
{
    <section class="container" style="padding-block:96px">
        <h1>Seite nicht gefunden</h1>
        <p style="margin-top:12px"><a href="/leistungen">Zurück zur Übersicht</a></p>
    </section>
}
else
{
    <PageTitle>@service.Title — ETD Elektrotechnik Desch</PageTitle>
    <HeadContent>
        <meta name="description" content="@service.ShortDescription" />
    </HeadContent>

    <ServiceDetailHero Eyebrow="Leistung" Title="@service.Title" Sub="@service.LongDescription" Icon="@service.Icon" />

    <section class="container fade-in" style="padding-block:64px">
        <div class="service-detail-grid">
            <div>
                <div class="eyebrow">Was Sie bekommen</div>
                <h2 style="margin-bottom:18px">Inkl. <em style="color:var(--red);font-style:normal">aller Schritte</em>, ohne Wenn und Aber.</h2>
                <ul style="font-size:1.0625rem;list-style:none;padding:0">
                    @foreach (var b in service.Bullets)
                    {
                        <li style="padding:10px 0 10px 28px;position:relative;border-top:1px solid var(--line)">
                            <span style="position:absolute;left:0;top:11px;color:var(--red);font-weight:800;font-size:1.25rem">✓</span>@b
                        </li>
                    }
                </ul>
            </div>
            <aside class="card service-detail-aside">
                <div class="eyebrow">So geht's weiter</div>
                <h3 style="margin-bottom:12px">Kostenfreies Angebot anfragen</h3>
                <p style="color:var(--muted);font-size:14px;margin-bottom:18px">Beschreiben Sie uns Ihr Projekt — Sie hören innerhalb 24 h von uns.</p>
                <a href="@($"/angebot?for={service.Slug}")" class="btn btn-primary" style="width:100%;justify-content:center">Angebot für @service.Title →</a>
                <p style="margin-top:14px;font-size:13px;color:var(--muted);text-align:center">oder anrufen: <a href="tel:+4960509062874" style="font-weight:700">06050 9062874</a></p>
            </aside>
        </div>
    </section>

    @if (visual is not null)
    {
        <section class="service-visual-band">
            <div class="container service-visual-grid fade-in">
                <div class="service-visual-copy">
                    <div class="eyebrow">@visual.Eyebrow</div>
                    <h2>@visual.Title</h2>
                    <p>@visual.Text</p>
                </div>
                <div class="service-visual-images">
                    @foreach (var image in visual.Images)
                    {
                        <figure class="service-visual-card">
                            <img src="@($"/img/legacy/{image.File}")" alt="@image.Alt" loading="lazy" />
                            <figcaption>@image.Caption</figcaption>
                        </figure>
                    }
                </div>
            </div>
        </section>
    }

    @if (service.Slug == "smart-home-knx")
    {
        <KnxRichContent />
    }
}
