                    <circle cx="0" cy="-4" r="2.5" fill="#dc1f26"/>
                    <path d="M-3 4 L3 4" stroke="#0e1116" stroke-width="1.5" stroke-linecap="round"/>
                </g>
                <g transform="translate(280 255)">
                    @* Switch / control *@
                    <rect x="-12" y="-10" width="24" height="20" rx="2" fill="#fff" stroke="#0e1116" stroke-width="1.5"/>
                    <circle cx="0" cy="0" r="3" fill="#0e1116"/>
                </g>

                @* Bus drops to devices *@
                <line x1="95" y1="155" x2="95" y2="155" stroke="#dc1f26" stroke-width="1.5"/>
                <line x1="210" y1="155" x2="210" y2="155" stroke="#dc1f26" stroke-width="1.5"/>
