@page "/angebot/kontakt"
@using System.ComponentModel.DataAnnotations
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav
@inject IQuoteMailer Mailer
@inject SubmissionRateLimiter Limiter
@inject IHttpContextAccessor Http
@inject ILogger<Kontakt> Log

<PageTitle>Angebot anfragen — Schritt 4 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="done"></div><div class="done"></div><div class="done"></div><div class="active"></div>
    </div>
    <div class="step-meta"><span>Schritt 4 von 4</span><span>Kontakt</span></div>

    @if (currentModel is null)
    {
        <p>Bitte mit <a href="/angebot">Schritt 1</a> beginnen.</p>
    }
    else
    {
        <h1 style="margin-bottom:24px">Ihre Kontaktdaten</h1>
        @* Only validate step-4 fields; carry previous state via prevToken hidden field. *@
        <EditForm Model="currentModel" OnSubmit="HandleSubmit" FormName="step4" Enhance>
            <input type="hidden" name="prevToken" value="@token" />

            <label>Name</label>
            <InputText @bind-Value="currentModel.Name" placeholder="Max Muster" />
            @if (nameError is not null) { <div class="field-error">@nameError</div> }

            <label style="margin-top:16px">E-Mail</label>
            <InputText @bind-Value="currentModel.Email" type="email" placeholder="max@example.de" />
            @if (emailError is not null) { <div class="field-error">@emailError</div> }

            <label style="margin-top:16px">Telefon</label>
            <InputText @bind-Value="currentModel.Phone" type="tel" placeholder="06050 9062874" />
            @if (phoneError is not null) { <div class="field-error">@phoneError</div> }

            <!-- Honeypot -->
            <div class="honeypot" aria-hidden="true">
                <label>Firma (bitte leer lassen)</label>
                <InputText @bind-Value="currentModel.CompanyName2" tabindex="-1" autocomplete="off" />
            </div>

            <label style="display:flex;gap:10px;align-items:flex-start;margin-top:18px">
                <InputCheckbox @bind-Value="currentModel.ConsentPrivacy" />
                <span style="font-size:13px;color:var(--ink-2)">Ich habe die <a href="/datenschutz" target="_blank">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu.</span>
            </label>
            @if (consentError is not null) { <div class="field-error">@consentError</div> }

            @if (errorMessage is not null)
            {
                <p class="field-error" style="margin-top:12px">@errorMessage</p>
            }

            <div class="nav-btns">
                <button type="button" class="btn btn-ghost" @onclick="HandleBack">← Zurück</button>
                <button type="submit" class="btn btn-primary" disabled="@submitting">Anfrage absenden →</button>
            </div>

            <p style="font-size:12px;color:var(--muted);margin-top:14px;text-align:center">Verschlüsselte Übertragung · keine Weitergabe an Dritte</p>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "s")] private string? token { get; set; }
    // Property name matches Razor expression prefix (currentModel.*) so the binder maps correctly.
    [SupplyParameterFromForm(FormName = "step4")] private QuoteRequest? currentModel { get; set; }
    // Previous step's encoded state carried as a hidden form field.
    [SupplyParameterFromForm(FormName = "step4")] private string? prevToken { get; set; }

    private bool submitting;
    private string? errorMessage;
    private string? nameError;
    private string? emailError;
    private string? phoneError;
    private string? consentError;

    protected override void OnParametersSet()
    {
        if (currentModel is not null)
        {
            // Form was submitted: restore steps 1-3 data from the previous token.
            if (prevToken is not null)
            {
                var prev = Protector.Unprotect(prevToken);
                if (prev is not null)
                {
                    currentModel.Services = prev.Services;
                    currentModel.Audience = prev.Audience;
                    currentModel.Notes = prev.Notes;
                    currentModel.Timeframe = prev.Timeframe;
                    currentModel.Plz = prev.Plz;
                    currentModel.City = prev.City;
                    currentModel.WallboxKw ??= prev.WallboxKw;
                    currentModel.WallboxDistanceMeters ??= prev.WallboxDistanceMeters;
                    currentModel.PvAreaSqm ??= prev.PvAreaSqm;
                    currentModel.PvStorageKwh ??= prev.PvStorageKwh;
                }
            }
        }
        else
        {
            // GET: load from query token.
            currentModel = Protector.Unprotect(token);
            currentModel ??= new QuoteRequest();
        }
    }

    private async Task HandleSubmit()
    {
        nameError = emailError = phoneError = consentError = null;
        bool valid = true;

        if (string.IsNullOrWhiteSpace(currentModel!.Name) || currentModel.Name.Length < 2)
        {
            nameError = "Bitte Vor- und Nachname eingeben.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(currentModel.Email) ||
            !System.Text.RegularExpressions.Regex.IsMatch(currentModel.Email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            emailError = "Bitte gültige E-Mail-Adresse eingeben.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(currentModel.Phone))
        {
            phoneError = "Telefonnummer ist erforderlich.";
            valid = false;
        }

        if (!currentModel.ConsentPrivacy)
        {
            consentError = "Bitte Datenschutzhinweis bestätigen.";
            valid = false;
        }

        if (!valid) return;

        // Honeypot — silently succeed without sending.
        if (!string.IsNullOrWhiteSpace(currentModel.CompanyName2))
        {
            Log.LogWarning("Honeypot triggered on quote submission");
            Nav.NavigateTo("/angebot/erfolg");
            return;
        }

        var ip = Http.HttpContext?.Connection.RemoteIpAddress?.ToString()
                 ?? Http.HttpContext?.Request.Headers["X-Forwarded-For"].ToString()
                 ?? "unknown";

        if (!Limiter.TryConsume(ip))
        {
            errorMessage = "Zu viele Anfragen in kurzer Zeit. Bitte versuchen Sie es in einer Stunde erneut oder rufen Sie uns an.";
            return;
        }

        submitting = true;
        try
        {
            await Mailer.SendAsync(currentModel);
            Nav.NavigateTo("/angebot/erfolg");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Mailer failed");
            errorMessage = "Der Versand ist fehlgeschlagen. Bitte rufen Sie uns direkt an: 06050 9062874.";
            submitting = false;
        }
    }

    private void HandleBack() => Nav.NavigateTo("/angebot/zeit-ort");
}
