@page "/datenschutz"

<PageTitle>Datenschutzerklärung — ETD</PageTitle>
<HeadContent>
    <meta name="description" content="Datenschutzerklärung von Elektrotechnik Desch — als PDF zum Lesen und Download." />
</HeadContent>

<section class="container fade-in" style="padding-block:64px;max-width:880px">
    <div class="eyebrow">Datenschutz</div>
    <h1>Datenschutzerklärung</h1>
    <p style="color:var(--muted);margin-top:8px;font-size:1.0625rem">
        Die vollständige Datenschutzerklärung steht hier als PDF zum Lesen und Download.
    </p>

    <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:24px;margin-bottom:32px">
        <a href="/dl/Datenschutzerklärung.pdf"
           class="btn btn-primary"
           download="Datenschutzerklaerung-Elektrotechnik-Desch.pdf">
            PDF herunterladen ↓
        </a>
        <a href="/dl/Datenschutzerklärung.pdf"
           class="btn btn-ghost"
           target="_blank" rel="noopener">
            In neuem Tab öffnen ↗
        </a>
    </div>

    <object data="/dl/Datenschutzerklärung.pdf#view=FitH"
            type="application/pdf"
            class="datenschutz-pdf"
            aria-label="Datenschutzerklärung PDF">
        <p>
            Ihr Browser kann das PDF nicht direkt anzeigen.
            <a href="/dl/Datenschutzerklärung.pdf">Bitte hier zum Download klicken.</a>
        </p>
    </object>

    <p style="color:var(--muted);font-size:14px;margin-top:20px">
        Bei Fragen zur Datenverarbeitung erreichen Sie uns unter
        <a href="mailto:mail@ElektroTechnikDesch.de">mail@ElektroTechnikDesch.de</a>.
    </p>
</section>
