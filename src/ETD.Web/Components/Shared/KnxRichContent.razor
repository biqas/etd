<!-- ============== USE-CASE GRID — WITH CONCRETE DEVICES + PRICES ============== -->
<section style="background:var(--white);padding:64px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
    <div class="container fade-in">
