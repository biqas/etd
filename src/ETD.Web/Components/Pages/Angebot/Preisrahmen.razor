@page "/angebot/preisrahmen"
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav

<PageTitle>Angebot anfragen — Schritt 2 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="done"></div><div class="active"></div><div></div><div></div>
    </div>
    <div class="step-meta"><span>Schritt 2 von 4</span><span>Preisrahmen (unverbindlich)</span></div>

    @if (currentModel is null)
    {
        <p>Bitte mit <a href="/angebot">Schritt 1</a> beginnen.</p>
    }
    else
    {
        <h1 style="margin-bottom:8px">Erste Kostenschätzung</h1>
        <p style="color:var(--muted);margin-bottom:18px">Nur ein Richtwert. Verbindlich nach Vor-Ort-Termin.</p>

        <EditForm Model="currentModel" OnValidSubmit="HandleNext" FormName="step2" Enhance>
            <input type="hidden" name="s" value="@token" />

            @if (currentModel.Services.Contains("elektroinstallation"))
            {
                var el = PriceEstimator.EstimateElektroinstallation(
                    currentModel.ElektroRoomCount ?? 5,
                    (currentModel.ElektroProjektart ?? "sanierung") == "neubau",
                    currentModel.ElektroZaehlerschrankNeu ?? false);
                <div class="param-block">
                    <h3 class="param-block-title">Elektroinstallation</h3>
                    <label class="slider-label">Projektart</label>
                    <div class="chips">
                        <label class="chip">
                            <input type="radio" name="ElektroProjektart" value="neubau" checked="@((currentModel.ElektroProjektart ?? "sanierung") == "neubau")" oninput="window.etdPrice && etdPrice.update()" />
                            Neubau
                        </label>
                        <label class="chip">
                            <input type="radio" name="ElektroProjektart" value="sanierung" checked="@((currentModel.ElektroProjektart ?? "sanierung") == "sanierung")" oninput="window.etdPrice && etdPrice.update()" />
                            Sanierung
                        </label>
                    </div>

                    <div class="slider-block">
                        <label class="slider-label">
                            Anzahl Räume
                            <span class="slider-value"><span data-out="el-rooms">@(currentModel.ElektroRoomCount ?? 5)</span></span>
                        </label>
                        <input class="range" type="range" name="ElektroRoomCount" min="1" max="12" step="1"
                               value="@(currentModel.ElektroRoomCount ?? 5)" oninput="window.etdPrice && etdPrice.update()" />
                        <div class="range-scale"><span>1</span><span>6</span><span>12</span></div>
                    </div>

                    <label class="checkbox-row">
                        <input type="checkbox" name="ElektroZaehlerschrankNeu" value="true" checked="@(currentModel.ElektroZaehlerschrankNeu == true)" oninput="window.etdPrice && etdPrice.update()" />
                        <span>Zählerschrank ebenfalls erneuern</span>
                    </label>

                    <div class="estimate-card">
                        <div class="estimate-label">Elektroinstallation · Richtwert (zzgl. MwSt.)</div>
                        <div class="estimate-amount" data-out="el-est">~ @($"{el.LowEuro:N0} – {el.HighEuro:N0}") €</div>
                    </div>
                </div>
            }

            @if (currentModel.Services.Contains("smart-home-knx"))
            {
                var knxFuncs = (currentModel.KnxFunctions ?? "light|blinds").Split('|', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
                var knxEst = PriceEstimator.EstimateKnx(currentModel.KnxRoomCount ?? 5, knxFuncs.Count);
                <div class="param-block">
                    <h3 class="param-block-title">Smart Home / KNX</h3>

                    <div class="slider-block">
                        <label class="slider-label">
                            Anzahl Räume mit Smart Home
                            <span class="slider-value"><span data-out="knx-rooms">@(currentModel.KnxRoomCount ?? 5)</span></span>
                        </label>
                        <input class="range" type="range" name="KnxRoomCount" min="1" max="12" step="1"
                               value="@(currentModel.KnxRoomCount ?? 5)" oninput="window.etdPrice && etdPrice.update()" />
                        <div class="range-scale"><span>1</span><span>6</span><span>12</span></div>
                    </div>

                    <label class="slider-label" style="margin-top:20px">Welche Funktionen?</label>
                    <input type="hidden" name="KnxFunctions" value="@(currentModel.KnxFunctions ?? "light|blinds")" id="knx-functions-raw" />
                    <div class="chips chips-wrap" id="knx-functions-group">
                        @foreach (var (slug, label) in new[]{ ("light","Lichtsteuerung"), ("blinds","Jalousien"), ("heating","Heizung"), ("scenes","Szenen"), ("security","Sicherheit"), ("voice","Sprachsteuerung") })
                        {
                            <label class="chip">
                                <input type="checkbox" data-knx-func="@slug" checked="@(knxFuncs.Contains(slug))" oninput="window.etdPrice && etdPrice.update()" />
                                @label
                            </label>
                        }
                    </div>

                    <div class="estimate-card">
                        <div class="estimate-label">KNX · Richtwert (zzgl. MwSt., je nach Funktionsumfang)</div>
                        <div class="estimate-amount" data-out="knx-est">~ @($"{knxEst.LowEuro:N0} – {knxEst.HighEuro:N0}") €</div>
                    </div>
                </div>
            }

            @if (currentModel.Services.Contains("klimatechnik"))
            {
                var klima = PriceEstimator.EstimateKlima(currentModel.KlimaRoomCount ?? 1, currentModel.KlimaSystem ?? "single");
                <div class="param-block">
                    <h3 class="param-block-title">Klima- & Kältetechnik</h3>

                    <div class="slider-block">
                        <label class="slider-label">
                            Anzahl Räume
                            <span class="slider-value"><span data-out="klima-rooms">@(currentModel.KlimaRoomCount ?? 1)</span></span>
                        </label>
                        <input class="range" type="range" name="KlimaRoomCount" min="1" max="8" step="1"
                               value="@(currentModel.KlimaRoomCount ?? 1)" oninput="window.etdPrice && etdPrice.update()" />
                        <div class="range-scale"><span>1</span><span>4</span><span>8</span></div>
                    </div>

                    <label class="slider-label" style="margin-top:20px">System</label>
                    <div class="chips chips-wrap">
                        <label class="chip">
                            <input type="radio" name="KlimaSystem" value="single" checked="@((currentModel.KlimaSystem ?? "single") == "single")" oninput="window.etdPrice && etdPrice.update()" />
                            Single-Split (1×)
                        </label>
                        <label class="chip">
                            <input type="radio" name="KlimaSystem" value="multi" checked="@(currentModel.KlimaSystem == "multi")" oninput="window.etdPrice && etdPrice.update()" />
                            Multi-Split (mehrere Räume)
                        </label>
                        <label class="chip">
                            <input type="radio" name="KlimaSystem" value="vrf" checked="@(currentModel.KlimaSystem == "vrf")" oninput="window.etdPrice && etdPrice.update()" />
                            VRF (Gewerbe)
                        </label>
                    </div>

                    <div class="estimate-card">
                        <div class="estimate-label">Klimatechnik · Richtwert (zzgl. MwSt.)</div>
                        <div class="estimate-amount" data-out="klima-est">~ @($"{klima.LowEuro:N0} – {klima.HighEuro:N0}") €</div>
                    </div>
                </div>
            }

            @if (currentModel.Services.Contains("sicherheit"))
            {
                var secComps = (currentModel.SecurityComponents ?? "alarm").Split('|', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
                var secEst = PriceEstimator.EstimateSecurity(secComps.Count, currentModel.SecuritySensorCount ?? 6);
                <div class="param-block">
                    <h3 class="param-block-title">Sicherheitstechnik</h3>

                    <label class="slider-label">Komponenten</label>
                    <input type="hidden" name="SecurityComponents" value="@(currentModel.SecurityComponents ?? "alarm")" id="sec-components-raw" />
                    <div class="chips chips-wrap" id="sec-components-group">
                        @foreach (var (slug, label) in new[]{ ("alarm","Alarm"), ("video","Videoüberwachung"), ("brandmelder","Brandmelder"), ("zutritt","Zutrittskontrolle") })
                        {
                            <label class="chip">
                                <input type="checkbox" data-sec-comp="@slug" checked="@(secComps.Contains(slug))" oninput="window.etdPrice && etdPrice.update()" />
                                @label
                            </label>
                        }
                    </div>

                    <div class="slider-block">
                        <label class="slider-label">
                            Geschätzte Anzahl Sensoren / Kameras
                            <span class="slider-value"><span data-out="sec-units">@(currentModel.SecuritySensorCount ?? 6)</span></span>
                        </label>
                        <input class="range" type="range" name="SecuritySensorCount" min="1" max="30" step="1"
                               value="@(currentModel.SecuritySensorCount ?? 6)" oninput="window.etdPrice && etdPrice.update()" />
                        <div class="range-scale"><span>1</span><span>15</span><span>30</span></div>
                    </div>

                    <div class="estimate-card">
                        <div class="estimate-label">Sicherheitstechnik · Richtwert (zzgl. MwSt.)</div>
                        <div class="estimate-amount" data-out="sec-est">~ @($"{secEst.LowEuro:N0} – {secEst.HighEuro:N0}") €</div>
                    </div>
                </div>
            }

            @if (currentModel.Services.Contains("wallbox"))
            {
                var wb = PriceEstimator.EstimateWallbox(currentModel.WallboxKw ?? 11, currentModel.WallboxDistanceMeters ?? 5);
                <div class="slider-block" data-calc="wallbox">
                    <label class="slider-label">
                        Wallbox-Leistung
                        <span class="slider-value"><span data-out="wb-kw">@(currentModel.WallboxKw ?? 11)</span> kW</span>
                    </label>
                    <input class="range" type="range" name="WallboxKw"
                           min="4" max="22" step="1"
                           value="@(currentModel.WallboxKw ?? 11)"
                           data-slider="wb-kw" oninput="window.etdPrice && etdPrice.update()" />
                    <div class="range-scale"><span>3,7 kW</span><span>11 kW</span><span>22 kW</span></div>
                </div>

                <div class="slider-block" data-calc="wallbox">
                    <label class="slider-label">
                        Entfernung zum Zählerschrank
                        <span class="slider-value"><span data-out="wb-dist">@(currentModel.WallboxDistanceMeters ?? 5)</span> m</span>
                    </label>
                    <input class="range" type="range" name="WallboxDistanceMeters"
                           min="1" max="50" step="1"
                           value="@(currentModel.WallboxDistanceMeters ?? 5)"
                           data-slider="wb-dist" oninput="window.etdPrice && etdPrice.update()" />
                    <div class="range-scale"><span>1 m</span><span>25 m</span><span>50 m</span></div>
                </div>

                <div class="estimate-card">
                    <div class="estimate-label">Wallbox · Richtwert (zzgl. MwSt.)</div>
                    <div class="estimate-amount" data-out="wb-est">~ @($"{wb.LowEuro:N0} – {wb.HighEuro:N0}") €</div>
                </div>
            }

            @if (currentModel.Services.Contains("photovoltaik"))
            {
                var pv = PriceEstimator.EstimatePv(currentModel.PvAreaSqm ?? 30, currentModel.PvStorageKwh ?? 0);
                var pvStorage = currentModel.PvStorageKwh ?? 0;
                <div class="slider-block" data-calc="pv">
                    <label class="slider-label">
                        Geschätzte Dachfläche
                        <span class="slider-value"><span data-out="pv-area">@(currentModel.PvAreaSqm ?? 30)</span> m²</span>
                    </label>
                    <input class="range" type="range" name="PvAreaSqm"
                           min="10" max="200" step="5"
                           value="@(currentModel.PvAreaSqm ?? 30)"
                           data-slider="pv-area" oninput="window.etdPrice && etdPrice.update()" />
                    <div class="range-scale"><span>10 m²</span><span>100 m²</span><span>200 m²</span></div>
                </div>

                <div class="slider-block" data-calc="pv">
                    <label class="slider-label">
                        Batteriespeicher
                        <span class="slider-value">
                            <span data-out="pv-storage">@(pvStorage == 0 ? "Kein" : pvStorage.ToString())</span>
                            <span data-out="pv-storage-unit">@(pvStorage == 0 ? "Speicher" : "kWh")</span>
                        </span>
                    </label>
                    <input class="range" type="range" name="PvStorageKwh"
                           min="0" max="20" step="1"
                           value="@pvStorage"
                           data-slider="pv-storage" oninput="window.etdPrice && etdPrice.update()" />
                    <div class="range-scale"><span>Kein</span><span>10 kWh</span><span>20 kWh</span></div>
                </div>

                <div class="estimate-card" style="margin-top:14px">
                    <div class="estimate-label">Photovoltaik · Richtwert (zzgl. MwSt.)</div>
                    <div class="estimate-amount" data-out="pv-est">~ @($"{pv.LowEuro:N0} – {pv.HighEuro:N0}") €</div>
                </div>
            }

            <p style="font-size:12px;color:var(--muted);margin-top:8px">Diese Schätzung ersetzt kein Angebot. Verbindlich erst nach Vor-Ort-Termin.</p>

            <div class="nav-btns">
                <button type="button" class="btn btn-ghost" @onclick="HandleBack">← Zurück</button>
                <button type="submit" class="btn btn-primary">Weiter →</button>
            </div>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "s")] private string? token { get; set; }
    [SupplyParameterFromForm(FormName = "step2")] private QuoteRequest? model { get; set; }

    private QuoteRequest? currentModel;

    protected override void OnParametersSet()
    {
        if (model is not null)
            currentModel = model;
        else
            currentModel = Protector.Unprotect(token);

        if (currentModel is not null)
        {
            currentModel.WallboxKw ??= 11;
            currentModel.WallboxDistanceMeters ??= 5;
            currentModel.PvAreaSqm ??= 30;
            currentModel.PvStorageKwh ??= 0;
            currentModel.ElektroProjektart ??= "sanierung";
            currentModel.ElektroRoomCount ??= 5;
            currentModel.ElektroZaehlerschrankNeu ??= false;
            currentModel.KnxRoomCount ??= 5;
            currentModel.KnxFunctions ??= "light|blinds";
            currentModel.KlimaRoomCount ??= 1;
            currentModel.KlimaSystem ??= "single";
            currentModel.SecurityComponents ??= "alarm";
            currentModel.SecuritySensorCount ??= 6;
        }
    }

    private void HandleNext()
    {
        Nav.NavigateTo($"/angebot/zeit-ort?s={Uri.EscapeDataString(Protector.Protect(currentModel!))}");
    }

    private void HandleBack() => Nav.NavigateTo("/angebot");
}
