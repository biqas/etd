@page "/Error"
@using System.Diagnostics
@layout MainLayout
@inject IWebHostEnvironment Env

<PageTitle>Fehler — ETD Elektrotechnik Desch</PageTitle>

<section class="container fade-in" style="padding:96px 0;min-height:60vh">
    <div style="max-width:680px">
        <div class="eyebrow">Etwas ist schiefgegangen</div>
        <h1 style="margin-bottom:14px">Da hat <em style="color:var(--red);font-style:normal">jemand was nicht hingekriegt.</em></h1>
        <p style="font-size:1.0625rem;color:var(--ink-2);line-height:1.55;margin-bottom:28px">Wir haben das Problem geloggt und schauen es uns an. In der Zwischenzeit:</p>

        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:32px">
            <a href="/" class="btn btn-primary">Zur Startseite</a>
            <a href="/kontakt" class="btn btn-ghost">Kontakt</a>
            <a href="tel:+4960509062874" class="btn btn-ghost">06050 9062874 anrufen</a>
        </div>

        @if (ShowRequestId)
        {
            <p style="font-size:13px;color:var(--muted);margin-top:24px">Falls Sie uns anrufen, nennen Sie bitte diese Referenz: <code>@RequestId</code></p>
        }

        @if (Env.IsDevelopment())
        {
            <details style="margin-top:32px;padding:16px;background:#fafafa;border:1px dashed var(--line);border-radius:8px">
                <summary style="cursor:pointer;font-weight:700;font-size:13px">Development-Hinweis</summary>
                <p style="font-size:13px;color:var(--muted);margin-top:8px">Dev-Modus: ASPNETCORE_ENVIRONMENT=Development setzen, um die volle Ausnahme zu sehen.</p>
            </details>
        }
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
