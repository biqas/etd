@page "/angebot/zeit-ort"
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav

<PageTitle>Angebot anfragen — Schritt 3 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="done"></div><div class="done"></div><div class="active"></div><div></div>
    </div>
    <div class="step-meta"><span>Schritt 3 von 4</span><span>Wann & wo?</span></div>

    @if (currentModel is null)
    {
        <p>Bitte mit <a href="/angebot">Schritt 1</a> beginnen.</p>
    }
    else
    {
        <h1 style="margin-bottom:24px">Wann & wo?</h1>
        <EditForm Model="currentModel" OnValidSubmit="HandleNext" FormName="step3" Enhance>
            <DataAnnotationsValidator />

            <label>Wunsch-Zeitrahmen</label>
            <div class="chips" style="flex-wrap:wrap">
                <label class="chip">
                    <input type="radio" name="currentModel.Timeframe" value="asap" checked="@(currentModel.Timeframe == "asap")" />
                    So bald wie möglich
                </label>
                <label class="chip">
                    <input type="radio" name="currentModel.Timeframe" value="2w" checked="@(currentModel.Timeframe == "2w")" />
                    Innerhalb 2 Wochen
                </label>
                <label class="chip">
                    <input type="radio" name="currentModel.Timeframe" value="4w" checked="@(currentModel.Timeframe == "4w")" />
                    Innerhalb 4 Wochen
                </label>
                <label class="chip">
                    <input type="radio" name="currentModel.Timeframe" value="flex" checked="@(currentModel.Timeframe == "flex")" />
                    Flexibel
                </label>
            </div>

            <label style="margin-top:24px">PLZ</label>
            <InputText @bind-Value="currentModel.Plz" maxlength="5" inputmode="numeric" placeholder="63599" />
            <ValidationMessage For="() => currentModel.Plz" class="field-error" />

            <label style="margin-top:16px">Ort</label>
            <InputText @bind-Value="currentModel.City" placeholder="Biebergemünd" />
            <ValidationMessage For="() => currentModel.City" class="field-error" />

            <div class="nav-btns">
                <button type="button" class="btn btn-ghost" @onclick="HandleBack">← Zurück</button>
                <button type="submit" class="btn btn-primary">Weiter →</button>
            </div>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "s")] private string? token { get; set; }
    [SupplyParameterFromForm(FormName = "step3")] private QuoteRequest? model { get; set; }

    private QuoteRequest? currentModel;

    protected override void OnParametersSet()
    {
        if (model is not null)
            currentModel = model;
        else
            currentModel = Protector.Unprotect(token);

        if (currentModel is not null && string.IsNullOrEmpty(currentModel.Timeframe))
            currentModel.Timeframe = "flex";
    }

    private void HandleNext()
    {
        Nav.NavigateTo($"/angebot/kontakt?s={Uri.EscapeDataString(Protector.Protect(currentModel!))}");
    }

    private void HandleBack()
    {
        var hasPrice = currentModel!.Services.Contains("wallbox") || currentModel.Services.Contains("photovoltaik");
        Nav.NavigateTo(hasPrice ? "/angebot/preisrahmen" : "/angebot");
    }
}
