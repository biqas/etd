@page "/angebot"
@using System.ComponentModel.DataAnnotations
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav

<PageTitle>Angebot anfragen — Schritt 1 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="active"></div><div></div><div></div><div></div>
    </div>
    <div class="step-meta"><span>Schritt 1 von 4</span><span>Was brauchen Sie?</span></div>
    <h1 style="margin-bottom:8px">Was brauchen Sie?</h1>
    <p style="color:var(--muted);margin-bottom:24px">Mehrfach-Auswahl möglich. Wenn unsicher: zur nächsten Frage springen — wir klären das im Telefon­gespräch.</p>

    @* Step 1 only validates Services — use OnSubmit to avoid full-model validation *@
    <EditForm Model="currentModel" OnSubmit="HandleSubmit" FormName="step1" Enhance>

        <div class="service-tiles" id="service-tiles">
            @foreach (var s in ServiceCatalog.All)
            {
                <label class="tile">
                    @* Visual-only checkbox; the real selection is tracked via the
                       hidden InputText below, which Blazor's form binder can bind. *@
                    <input type="checkbox" data-service="@s.Slug" value="@s.Slug"
                           checked="@(currentModel.Services.Contains(s.Slug))" />
                    <span class="tile-icon"><ServiceIcon Name="@s.Icon" Size="16" /></span>
                    <span>@s.Title</span>
                </label>
            }
        </div>
        @* Hidden bound field — Blazor's InputText registers with the EditForm
           so SupplyParameterFromForm can bind ServicesRaw correctly. *@
        <InputText id="services-raw" type="hidden" @bind-Value="currentModel.ServicesRaw" />
        @if (servicesError is not null)
        {
            <div class="field-error">@servicesError</div>
        }

        <label style="margin-top:24px">Für wen?</label>
        <div class="chips">
            <label class="chip">
                <input type="radio" name="currentModel.Audience" value="privat" checked="@(currentModel.Audience == "privat")" />
                Privat
            </label>
            <label class="chip">
                <input type="radio" name="currentModel.Audience" value="gewerbe" checked="@(currentModel.Audience == "gewerbe")" />
                Gewerbe
            </label>
        </div>

        <label style="margin-top:24px">Weitere Hinweise (optional)</label>
        <InputTextArea @bind-Value="currentModel.Notes" placeholder="Was sollen wir noch wissen? (Termin, Anzahl Räume, Sondersituationen ...)" />

        <div class="nav-btns">
            <button type="submit" class="btn btn-primary">Weiter →</button>
        </div>
    </EditForm>
</section>

@code {
    // Always-non-null backing field — the markup reads currentModel directly, never sees null.
    private QuoteRequest _model = new QuoteRequest { Audience = "privat" };

    // Property name MUST match the EditForm Model expression so Blazor's form binder
    // writes posted "currentModel.X" fields into this property.
    // Setter is defensive: a null incoming value (no form data) leaves the existing instance intact.
    [SupplyParameterFromForm(FormName = "step1")]
    private QuoteRequest currentModel
    {
        get => _model;
        set { if (value is not null) _model = value; }
    }

    // Optional pre-selected service from the URL (?for=slug). When set we auto-skip Step 1.
    [SupplyParameterFromQuery(Name = "for")] private string? PrefilledService { get; set; }

    private string? servicesError;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_model.Audience)) _model.Audience = "privat";

        // ServicesRaw is the bound hidden field. Translate it into the typed Services list.
        if (!string.IsNullOrWhiteSpace(_model.ServicesRaw))
        {
            _model.Services = _model.ServicesRaw
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
        }

        // Fast-track: a tile click passed ?for=slug → skip step 1 entirely.
        if (!string.IsNullOrWhiteSpace(PrefilledService) && _model.Services.Count == 0)
        {
            var match = ServiceCatalog.FindBySlug(PrefilledService);
            if (match is not null)
            {
                _model.Services = new List<string> { match.Slug };
                var hasParams = ServiceParams.HasParamsFor(match.Slug);
                var next = hasParams ? "/angebot/preisrahmen" : "/angebot/zeit-ort";
                Nav.NavigateTo($"{next}?s={Uri.EscapeDataString(Protector.Protect(_model))}", replace: true);
            }
        }
    }

    private void HandleSubmit()
    {
        servicesError = null;
        if (_model.Services.Count == 0)
        {
            servicesError = "Bitte mindestens eine Leistung auswählen.";
            return;
        }

        var hasParams = ServiceParams.HasParamsForAny(_model.Services);
        var next = hasParams ? "/angebot/preisrahmen" : "/angebot/zeit-ort";
        Nav.NavigateTo($"{next}?s={Uri.EscapeDataString(Protector.Protect(_model))}");
    }
}

<script>
(function () {
    function syncServices() {
        var tiles = document.getElementById('service-tiles');
        var raw = document.getElementById('services-raw');
        if (!tiles || !raw) return;
        var slugs = [];
        tiles.querySelectorAll('input[data-service]:checked').forEach(function (cb) {
            slugs.push(cb.value);
        });
        raw.value = slugs.join(',');
    }

    function init() {
        var tiles = document.getElementById('service-tiles');
        if (!tiles) return;
        syncServices();
        tiles.addEventListener('change', syncServices);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
    document.addEventListener('enhancedload', init);
})();
</script>
