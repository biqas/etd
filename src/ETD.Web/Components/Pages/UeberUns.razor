@page "/ueber-uns"
@using ETD.Web.Components.Shared

<PageTitle>Über uns — ETD</PageTitle>

<ServiceDetailHero Eyebrow="Über uns" Title="Christoph Desch · Meister­betrieb." Sub="Seit Jahren als zuverlässiger Partner für Privat- und Gewerbekunden in der Region Main-Kinzig-Kreis." />

<section class="about-section fade-in">
    <div class="container about-grid">
        <figure class="about-photo-card">
            <img src="/img/legacy/ueberuns-werkstatt-IMG_20250911.jpg" alt="Meisterbrief von Christoph Desch" loading="lazy" />
            <figcaption>
                <strong>Meisterbrief Christoph Desch</strong>
                <span>Elektrotechniker-Handwerk, Handwerkskammer Frankfurt-Rhein-Main</span>
            </figcaption>
        </figure>

        <div class="about-copy">
            <div class="eyebrow">Qualifikationen</div>
            <h2>Zertifikate und <em style="color:var(--red);font-style:normal">Mitgliedschaften.</em></h2>
            <p>ETD verbindet klassisches Elektrohandwerk mit Kälte- und Klimatechnik. Für Kunden heißt das: ein Ansprechpartner für Planung, Installation, Inbetriebnahme und saubere Dokumentation.</p>
            <ul class="about-qual-list">
                <li>Elektrotechniker­meister (HWK)</li>
                <li>Innungsmitglied</li>
                <li>Sachkundezertifikat A1 für Kältetechnik</li>
                <li>Betriebszertifizierung gemäß §6 ChemKlimaschutzV</li>
            </ul>

            <div class="about-cert-grid" aria-label="Zertifikate und Nachweise">
                @foreach (var cert in Certificates)
                {
                    <a class="about-cert-card" href="@($"/img/legacy/{cert.File}")" target="_blank" rel="noopener">
                        <img src="@($"/img/legacy/{cert.File}")" alt="@cert.Alt" loading="lazy" />
                        <span>@cert.Label</span>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private static readonly (string File, string Label, string Alt)[] Certificates =
    [
        ("zert-innungsmitgliedschaft.jpg", "Innungsmitgliedschaft", "Scan der Innungsmitgliedschaft von Elektrotechnik Desch"),
        ("zert-qb-christoph-desch.png", "Sachkunde A1", "Qualifikationsnachweis Sachkunde A1 Christoph Desch"),
        ("zert-chemklimaschutzv.png", "ChemKlimaschutzV", "Betriebszertifikat nach §6 ChemKlimaschutzV"),
    ];
}
