                <line x1="115" y1="245" x2="115" y2="245" stroke="#dc1f26" stroke-width="1.5"/>
                <line x1="280" y1="245" x2="280" y2="245" stroke="#dc1f26" stroke-width="1.5"/>

                @* Smartphone, top right, connected via wifi *@
