@page "/kontakt"
@using ETD.Web.Components.Shared

<PageTitle>Kontakt — ETD</PageTitle>

<ServiceDetailHero Eyebrow="Kontakt" Title="So erreichen Sie uns." Sub="Direkter Draht zum Meisterbetrieb — Anruf, E-Mail oder Angebotsanfrage." />

<section class="container fade-in kontakt-section">
    <div class="kontakt-grid">
        <div>
            <div class="eyebrow">Adresse</div>
            <h2 style="margin-bottom:18px">Elektrotechnik Desch</h2>
            <p style="font-size:1.0625rem;line-height:1.8">
                Von-Cancrin-Straße 22<br/>
                63599 Biebergemünd<br/>
                Hessen, Deutschland
            </p>
            <div class="kontakt-actions">
                <a href="tel:+4960509062874" class="btn btn-primary" style="justify-content:flex-start"><ServiceIcon Name="phone" Size="18" /> 06050 9062874</a>
                <a href="mailto:mail@ElektroTechnikDesch.de" class="btn btn-ghost" style="justify-content:flex-start"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> mail@ElektroTechnikDesch.de</a>
                <a href="/angebot" class="btn btn-ghost" style="justify-content:flex-start"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg> Angebot anfragen</a>
            </div>
        </div>
        <div class="kontakt-map">
            <div class="card kontakt-map-card">
                <a href="https://www.openstreetmap.org/?mlat=50.1583&amp;mlon=9.3556#map=15/50.1583/9.3556"
                   target="_blank" rel="noopener" aria-label="OpenStreetMap für Biebergemünd, Von-Cancrin-Straße 22 öffnen">
                    <svg class="kontakt-map-svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Karte Biebergemünd Lageplan">
                        <defs>
                            <pattern id="mapGrid" width="40" height="40" patternUnits="userSpaceOnUse">
                                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(14,17,22,0.045)" stroke-width="1"/>
                            </pattern>
                            <linearGradient id="parkGrad" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0" stop-color="#cfe6c8"/>
                                <stop offset="1" stop-color="#a8d29c"/>
                            </linearGradient>
                            <linearGradient id="riverGrad" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0" stop-color="#bcd9e8"/>
                                <stop offset="1" stop-color="#7fb6cc"/>
                            </linearGradient>
                            <filter id="pinShadow" x="-50%" y="-50%" width="200%" height="200%">
                                <feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="rgba(0,0,0,0.35)"/>
                            </filter>
                        </defs>

                        <rect width="800" height="500" fill="#f4eee5"/>
                        <rect width="800" height="500" fill="url(#mapGrid)"/>

                        @* Wald-/Parkflächen (Spessart-Ausläufer) *@
                        <path d="M0,360 Q120,300 240,330 T520,310 T800,340 L800,500 L0,500 Z" fill="url(#parkGrad)" opacity="0.85"/>
                        <path d="M0,0 Q140,80 280,40 T580,70 T800,30 L800,140 Q620,180 420,150 T120,180 L0,160 Z" fill="url(#parkGrad)" opacity="0.6"/>

                        @* Bieber-Fluss *@
                        <path d="M-20,250 Q160,220 320,260 T620,240 T820,280" fill="none" stroke="url(#riverGrad)" stroke-width="12" stroke-linecap="round"/>

                        @* Hauptstraßen *@
                        <line x1="0" y1="180" x2="800" y2="220" stroke="#ffffff" stroke-width="8"/>
                        <line x1="0" y1="180" x2="800" y2="220" stroke="#d6c9b3" stroke-width="2" stroke-dasharray="14 6"/>
                        <line x1="120" y1="0" x2="180" y2="500" stroke="#ffffff" stroke-width="6"/>
                        <line x1="120" y1="0" x2="180" y2="500" stroke="#d6c9b3" stroke-width="1.5" stroke-dasharray="10 6"/>
                        <line x1="640" y1="0" x2="600" y2="500" stroke="#ffffff" stroke-width="6"/>
                        <line x1="640" y1="0" x2="600" y2="500" stroke="#d6c9b3" stroke-width="1.5" stroke-dasharray="10 6"/>

                        @* Nebenstraßen *@
                        <line x1="200" y1="120" x2="700" y2="140" stroke="#ffffff" stroke-width="4"/>
                        <line x1="200" y1="400" x2="700" y2="420" stroke="#ffffff" stroke-width="4"/>
                        <line x1="320" y1="0" x2="340" y2="500" stroke="#ffffff" stroke-width="3"/>
                        <line x1="480" y1="0" x2="500" y2="500" stroke="#ffffff" stroke-width="3"/>

                        @* Häuserblöcke (Andeutungen) *@
                        <g fill="#e2d7c2" opacity="0.85">
                            <rect x="200" y="190" width="80" height="40"/>
                            <rect x="300" y="195" width="60" height="35"/>
                            <rect x="380" y="200" width="70" height="35"/>
                            <rect x="490" y="205" width="80" height="40"/>
                            <rect x="220" y="280" width="60" height="50"/>
                            <rect x="310" y="290" width="70" height="45"/>
                            <rect x="430" y="295" width="60" height="50"/>
                            <rect x="520" y="290" width="70" height="50"/>
                        </g>

                        @* Stadtname *@
                        <text x="40" y="50" font-family="Inter, sans-serif" font-size="22" font-weight="700" fill="#0e1116">Biebergemünd</text>
                        <text x="40" y="72" font-family="Inter, sans-serif" font-size="12" font-weight="500" fill="#6b6b6b" letter-spacing="0.08em">MAIN-KINZIG-KREIS · HESSEN</text>

                        @* Pin auf Adresse (Mitte) *@
                        <g transform="translate(400, 245)" filter="url(#pinShadow)">
                            <path d="M 0,-30 C -14,-30 -22,-20 -22,-8 C -22,8 0,30 0,30 C 0,30 22,8 22,-8 C 22,-20 14,-30 0,-30 Z" fill="#DC1F26" stroke="#a3171c" stroke-width="1.5"/>
                            <circle cx="0" cy="-10" r="6" fill="#ffffff"/>
                        </g>

                        @* Adress-Label neben Pin *@
                        <g transform="translate(430, 270)">
                            <rect x="0" y="0" width="240" height="56" rx="6" fill="#ffffff" stroke="rgba(14,17,22,0.12)" stroke-width="1"/>
                            <text x="14" y="22" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="#0e1116">ETD · Elektrotechnik Desch</text>
                            <text x="14" y="42" font-family="Inter, sans-serif" font-size="11" font-weight="500" fill="#6b6b6b">Von-Cancrin-Straße 22</text>
                        </g>

                        @* Maßstab unten links *@
                        <g transform="translate(40, 460)">
                            <line x1="0" y1="0" x2="100" y2="0" stroke="#0e1116" stroke-width="2"/>
                            <line x1="0" y1="-5" x2="0" y2="5" stroke="#0e1116" stroke-width="2"/>
                            <line x1="100" y1="-5" x2="100" y2="5" stroke="#0e1116" stroke-width="2"/>
                            <text x="50" y="-10" font-family="Inter, sans-serif" font-size="10" font-weight="600" fill="#0e1116" text-anchor="middle">200 m</text>
                        </g>

                        @* Attribution *@
                        <text x="790" y="490" font-family="Inter, sans-serif" font-size="9" fill="#6b6b6b" text-anchor="end">Konzeptskizze · Detailkarte: OpenStreetMap</text>
                    </svg>
                </a>
                <div class="kontakt-map-cap">Klick öffnet OpenStreetMap in neuem Tab</div>
            </div>
        </div>
    </div>
</section>
