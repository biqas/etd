@page "/angebot/zeit-ort"
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav

<PageTitle>Angebot anfragen — Schritt 3 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="done"></div><div class="done"></div><div class="active"></div><div></div>
    </div>
    <div class="step-meta"><span>Schritt 3 von 4</span><span>Wann & wo?</span></div>

    @if (currentModel is null)
    {
        <p>Bitte mit <a href="/angebot">Schritt 1</a> beginnen.</p>
    }
    else
    {
        <h1 style="margin-bottom:24px">Wann & wo?</h1>
        @* Only validate step-3 fields; use OnSubmit to skip full-model validation.
           Include the token as a hidden field so the previous step's data is available on POST. *@
        <EditForm Model="currentModel" OnSubmit="HandleSubmit" FormName="step3" Enhance>
            <input type="hidden" name="prevToken" value="@token" />

            <label>Wunsch-Zeitrahmen</label>
            @* TimeframeRaw is a bound hidden field — JS syncs the selected chip value into it. *@
            <InputText id="timeframe-raw" type="hidden" @bind-Value="currentModel.TimeframeRaw" />
            <div class="chips" style="flex-wrap:wrap" id="timeframe-chips">
                <label class="chip">
                    <input type="radio" name="timeframe-pick" data-timeframe="asap" value="asap" checked="@(currentModel.Timeframe == "asap")" />
                    So bald wie möglich
                </label>
                <label class="chip">
                    <input type="radio" name="timeframe-pick" data-timeframe="2w" value="2w" checked="@(currentModel.Timeframe == "2w")" />
                    Innerhalb 2 Wochen
                </label>
                <label class="chip">
                    <input type="radio" name="timeframe-pick" data-timeframe="4w" value="4w" checked="@(currentModel.Timeframe == "4w")" />
                    Innerhalb 4 Wochen
                </label>
                <label class="chip">
                    <input type="radio" name="timeframe-pick" data-timeframe="flex" value="flex" checked="@(currentModel.Timeframe == "flex")" />
                    Flexibel
                </label>
            </div>

            <label style="margin-top:24px">PLZ</label>
            <InputText @bind-Value="currentModel.Plz" maxlength="5" inputmode="numeric" placeholder="63599" />
            @if (plzError is not null) { <div class="field-error">@plzError</div> }

            <label style="margin-top:16px">Ort</label>
            <InputText @bind-Value="currentModel.City" placeholder="Biebergemünd" />
            @if (cityError is not null) { <div class="field-error">@cityError</div> }

            <div class="nav-btns">
                <button type="button" class="btn btn-ghost" @onclick="HandleBack">← Zurück</button>
                <button type="submit" class="btn btn-primary">Weiter →</button>
            </div>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "s")] private string? token { get; set; }
    // Property name matches Razor expression prefix (currentModel.*) so the binder maps correctly.
    [SupplyParameterFromForm(FormName = "step3")] private QuoteRequest? currentModel { get; set; }
    // Previous step's encoded state, carried as a hidden form field.
    [SupplyParameterFromForm(FormName = "step3")] private string? prevToken { get; set; }

    protected override void OnParametersSet()
    {
        if (currentModel is not null)
        {
            // Form was submitted: merge step-3 fields into the state from the previous token.
            // Timeframe comes from the TimeframeRaw hidden InputText (since raw radios don't bind).
            if (!string.IsNullOrWhiteSpace(currentModel.TimeframeRaw))
                currentModel.Timeframe = currentModel.TimeframeRaw;

            // Restore step-1 data (Services etc.) from the previous state token.
            if (prevToken is not null)
            {
                var prev = Protector.Unprotect(prevToken);
                if (prev is not null)
                {
                    currentModel.Services = prev.Services;
                    currentModel.Audience = prev.Audience;
                    currentModel.Notes = prev.Notes;
                    currentModel.SelectedFeatures = prev.SelectedFeatures ?? new();
                    currentModel.SelectedFeaturesRaw = prev.SelectedFeaturesRaw;
                }
            }
        }
        else
        {
            // GET: load from query token.
            currentModel = Protector.Unprotect(token);
        }

        if (currentModel is not null && string.IsNullOrEmpty(currentModel.Timeframe))
            currentModel.Timeframe = "flex";
    }

    private string? plzError;
    private string? cityError;

    private void HandleSubmit()
    {
        plzError = null;
        cityError = null;
        bool valid = true;

        if (string.IsNullOrWhiteSpace(currentModel?.Plz) || !System.Text.RegularExpressions.Regex.IsMatch(currentModel.Plz, @"^\d{5}$"))
        {
            plzError = "Bitte 5-stellige PLZ eingeben.";
            valid = false;
        }

        if (string.IsNullOrWhiteSpace(currentModel?.City))
        {
            cityError = "Ort ist erforderlich.";
            valid = false;
        }

        if (valid)
            Nav.NavigateTo($"/angebot/kontakt?s={Uri.EscapeDataString(Protector.Protect(currentModel!))}");
    }

    private void HandleBack()
    {
        if (currentModel is not null)
            Nav.NavigateTo($"/angebot/preisrahmen?s={Uri.EscapeDataString(Protector.Protect(currentModel))}");
        else
            Nav.NavigateTo("/angebot/preisrahmen");
    }
}

<script>
(function () {
    function syncTimeframe() {
        var chips = document.getElementById('timeframe-chips');
        var raw = document.getElementById('timeframe-raw');
        if (!chips || !raw) return;
        var checked = chips.querySelector('input[data-timeframe]:checked');
        if (checked) raw.value = checked.value;
    }

    function init() {
        var chips = document.getElementById('timeframe-chips');
        if (!chips) return;
        syncTimeframe();
        chips.addEventListener('change', syncTimeframe);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
    document.addEventListener('enhancedload', init);
})();
</script>
