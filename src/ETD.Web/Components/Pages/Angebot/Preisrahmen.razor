@page "/angebot/preisrahmen"
@using ETD.Web.Models
@using ETD.Web.Services
@inject WizardStateProtector Protector
@inject NavigationManager Nav

<PageTitle>Angebot anfragen — Schritt 2 — ETD</PageTitle>

<section class="wizard fade-in">
    <div class="stepper">
        <div class="done"></div><div class="active"></div><div></div><div></div>
    </div>
    <div class="step-meta"><span>Schritt 2 von 4</span><span>Was soll gemacht werden?</span></div>

    @if (currentModel is null)
    {
        <div style="padding:24px;background:var(--red-soft);border-left:4px solid var(--red);border-radius:8px;margin:24px 0">
            <strong style="display:block;margin-bottom:6px">Ihre vorherige Auswahl ist abgelaufen.</strong>
            <p style="color:var(--ink-2);font-size:14px;margin-bottom:12px">Tokens sind aus Sicherheitsgründen kurzlebig. Starten Sie kurz neu — wir merken uns die Schritte dieses Mal sauber.</p>
            <a href="/angebot" class="btn btn-primary">Zurück zu Schritt 1 →</a>
        </div>
    }
    else
    {
        <h1 style="margin-bottom:8px">Was soll konkret gemacht werden?</h1>
        <p style="color:var(--muted);margin-bottom:18px">Mehrfach­auswahl möglich. Wenn unsicher: <strong>einfach alles ankreuzen, was Sie interessiert</strong> — wir klären im Vor-Ort-Termin Details &amp; Preisrahmen.</p>

        <EditForm Model="currentModel" OnSubmit="HandleNext" FormName="step2" Enhance>
            <input type="hidden" name="s" value="@token" />

            @* Hidden field that JS keeps in sync with the checkbox state *@
            <input type="hidden" name="SelectedFeaturesRaw" id="features-raw" value="@(currentModel.SelectedFeaturesRaw ?? "")" />

            @foreach (var svc in selectedServices)
            {
                <div class="feature-block">
                    <h3 class="feature-block-title">
                        <span class="feature-block-icon"><ServiceIcon Name="@svc.Icon" Size="20" /></span>
                        @svc.Title
                    </h3>
                    <div class="feature-list" data-service-slug="@svc.Slug">
                        @foreach (var feature in svc.Bullets)
                        {
                            var key = $"{svc.Slug}::{feature}";
                            <label class="feature-row">
                                <input type="checkbox" data-feature="@key" checked="@(currentModel.SelectedFeatures.Contains(key))" />
                                <span class="feature-row-check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                                <span class="feature-row-label">@feature</span>
                            </label>
                        }
                        <label class="feature-row feature-row-other">
                            <input type="checkbox" data-feature="@($"{svc.Slug}::Sonstiges / im Termin klären")" checked="@(currentModel.SelectedFeatures.Contains($"{svc.Slug}::Sonstiges / im Termin klären"))" />
                            <span class="feature-row-check"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                            <span class="feature-row-label"><em>Sonstiges / im Termin klären</em></span>
                        </label>
                    </div>
                </div>
            }

            <p style="font-size:12px;color:var(--muted);margin-top:18px">Sie bekommen <strong>kein</strong> automatisches Angebot — wir besprechen alles im persönlichen Termin und liefern dann einen verbindlichen Festpreis.</p>

            <div class="nav-btns">
                <button type="button" class="btn btn-ghost" @onclick="HandleBack">← Zurück</button>
                <button type="submit" class="btn btn-primary">Weiter →</button>
            </div>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromQuery(Name = "s")] private string? token { get; set; }
    [SupplyParameterFromForm(FormName = "step2")] private QuoteRequest? model { get; set; }

    private QuoteRequest? currentModel;
    private List<ServiceItem> selectedServices = new();

    protected override void OnParametersSet()
    {
        currentModel = model ?? Protector.Unprotect(token);

        if (currentModel is null) return;

        currentModel.SelectedFeatures ??= new();

        // Parse raw → list on POST (form binder writes SelectedFeaturesRaw)
        if (!string.IsNullOrWhiteSpace(currentModel.SelectedFeaturesRaw))
        {
            currentModel.SelectedFeatures = currentModel.SelectedFeaturesRaw
                .Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct()
                .ToList();
        }

        selectedServices = currentModel.Services
            .Select(slug => ServiceCatalog.FindBySlug(slug))
            .Where(s => s is not null)
            .Cast<ServiceItem>()
            .ToList();
    }

    private void HandleNext()
    {
        // Persist the parsed list back into raw so it survives the state token
        currentModel!.SelectedFeaturesRaw = string.Join('|', currentModel.SelectedFeatures ?? new List<string>());
        Nav.NavigateTo($"/angebot/zeit-ort?s={Uri.EscapeDataString(Protector.Protect(currentModel))}");
    }

    private void HandleBack()
    {
        // Persist current state back into raw before backing out so /angebot can rehydrate it
        if (currentModel is not null)
        {
            currentModel.SelectedFeaturesRaw = string.Join('|', currentModel.SelectedFeatures ?? new List<string>());
            Nav.NavigateTo($"/angebot?s={Uri.EscapeDataString(Protector.Protect(currentModel))}");
        }
        else
        {
            Nav.NavigateTo("/angebot");
        }
    }
}

<script>
(function () {
    function sync() {
        var lists = document.querySelectorAll('.feature-list');
        var raw = document.getElementById('features-raw');
        if (!raw) return;
        var picked = [];
        lists.forEach(function (list) {
            list.querySelectorAll('input[type=checkbox][data-feature]:checked').forEach(function (cb) {
                picked.push(cb.getAttribute('data-feature'));
            });
        });
        raw.value = picked.join('|');
    }
    function init() {
        var lists = document.querySelectorAll('.feature-list');
        if (!lists.length) return;
        sync();
        lists.forEach(function (list) {
            list.addEventListener('change', sync);
        });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
    document.addEventListener('enhancedload', init);
})();
</script>
